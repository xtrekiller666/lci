# LCI Environment Configuration

# --- Required ---
# Your OpenAI-compatible API Key
OPENAI_API_KEY=

# --- Optional ---
# Base URL for LLM provider (defaults to OpenAI)
# For local models (Ollama): http://localhost:11434/v1
# For LM Studio: http://localhost:1234/v1
OPENAI_BASE_URL=https://api.openai.com/v1

# LLM Model name
LLM_MODEL=gpt-4o

# User display name (used in logs and achievements)
USER_NAME=User

# Database path (relative to project root)
DB_PATH=data/lci_main.db
